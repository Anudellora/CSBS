# Шаблон для .env. Скопируйте в backend/.env и заполните реальными значениями.
# Файл .env (с реальными секретами) в git не коммитится — см. .gitignore.

# Database
# Для локального запуска (go run) — localhost.
# Для запуска в docker compose — переопределяется на "postgres" в docker-compose.yml.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=csbs

# Server
SERVER_PORT=8080

# Gemini API
# Получить ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# HTTP/HTTPS/SOCKS5 прокси для обхода геоблока Gemini.
# Пример: http://user:pass@proxy.example.com:8080 или socks5://127.0.0.1:1080
# Оставить пустым — запросы пойдут напрямую.
GEMINI_PROXY_URL=

# Кастомный DNS для резолва хостов Gemini (xbox-dns.ru).
# Несколько серверов через запятую; порт обязателен (53 для plain DNS).
GEMINI_DNS=111.88.96.50:53,111.88.96.51:53

# GigaChat (Сбер). Авторизационные данные в base64 (Client ID:Client Secret).
# Получить: https://developers.sber.ru/studio/workspaces -> создать проект GigaChat API.
GIGACHAT_AUTH_KEY=
# Scope: GIGACHAT_API_PERS (физлица), GIGACHAT_API_B2B или GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель: GigaChat, GigaChat-Pro, GigaChat-Max
GIGACHAT_MODEL=GigaChat
# Серверы Сбера используют сертификаты Минцифры. По умолчанию проверка TLS отключена.
# Для production: установите корневой сертификат "Russian Trusted Root CA" и поставьте false.
GIGACHAT_INSECURE_SKIP_VERIFY=true

# SMTP (Google Gmail)
# Шаг 1: включите 2-шаговую аутентификацию: https://myaccount.google.com/security
# Шаг 2: создайте App Password: https://myaccount.google.com/apppasswords
# Шаг 3: вставьте email и 16-значный app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# URL фронтенда для ссылки в письме
APP_URL=http://localhost:5173

# Kafka (опционально).
# Для локального запуска (go run) — localhost.
# Для docker compose — переопределяется на "kafka:9092" в docker-compose.yml.
# Если пусто — продюсер и консьюмеры не стартуют, остальное приложение работает как обычно.
KAFKA_BROKERS=localhost:9092

# Лицензирование (офлайн-проверка подписанного JWT, алгоритм Ed25519).
# Асимметрия: приватный ключ только у вендора (выпускает токены утилитой
# cmd/licensegen), бэкенд знает лишь публичный ключ и может только проверить подпись.
#
# Сгенерировать пару ключей (один раз, на машине вендора):
#   go run ./cmd/licensegen -genkeys
# Выпустить лицензию клиенту:
#   go run ./cmd/licensegen -key "<приватный ключ>" -customer acme -plan pro \
#       -features ai_chat,analytics,kafka -users 50 -workspaces 200 -days 365
#
# LICENSE_PUBLIC_KEY — публичный ключ (base64). Пусто → платные функции отключены.
LICENSE_PUBLIC_KEY=
# LICENSE_KEY — подписанный токен. Резервный источник, если в БД нет активной
# лицензии (лицензию также можно установить через POST /api/license из админки).
LICENSE_KEY=
